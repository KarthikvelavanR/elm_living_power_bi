{
  "name": "Elm_Living_Purple_Theme",
  "dataColors": [
    "#6D28D9",
    "#9333EA",
    "#C084FC",
    "#A78BFA",
    "#7C3AED",
    "#4F46E5",
    "#6366F1",
    "#8B5CF6"
  ],
  "background": "#F5F3FF",
  "foreground": "#1F2937",
  "tableAccent": "#6D28D9",

  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#EDE9FE" } },
            "transparency": 10
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#C4B5FD" } },
            "radius": 14
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#1F2937" } },
            "fontSize": 14,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },

    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#6D28D9" } },
            "fontSize": 28
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 12
          }
        ]
      }
    },

    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "backColor": { "solid": { "color": "#6D28D9" } },
            "fontColor": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "grid": [
          {
            "outlineColor": { "solid": { "color": "#DDD6FE" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#EDE9FE" } }
          }
        ],
        "selection": [
          {
            "color": { "solid": { "color": "#6D28D9" } }
          }
        ]
      }
    }
  }
}